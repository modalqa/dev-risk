generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id               String              @id @default(uuid())
  name             String
  slug             String              @unique
  status           TenantStatus        @default(ACTIVE)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  auditLogs        AuditLog[]
  notifications    Notification[]
  releases         Release[]
  risks            Risk[]
  users            User[]
  aiAnalysisResults AiAnalysisResult[]

  @@index([status])
}


model User {
  id           String   @id @default(uuid())
  email        String
  passwordHash String
  name         String
  role         UserRole
  isActive     Boolean  @default(true)
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([email, tenantId])
  @@index([tenantId])
}

model SuperAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Super Admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AiAnalysisResult {
  id              String   @id @default(uuid())
  releaseId       String
  tenantId        String
  analysisType    String   // 'risk_mitigation', 'pattern_analysis', etc.
  riskPatterns    Json     // Array of identified patterns
  recommendations Json     // Array of AI recommendations
  improvements    Json     // List of improvements made
  confidenceScore Float    @default(0.5)
  risksAnalyzed   Int      @default(0)
  risksUpdated    Int      @default(0)
  beforeMetrics   Json     // Metrics before AI processing
  afterMetrics    Json     // Metrics after AI processing
  processingTime  Int      // Processing time in milliseconds
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  release Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([releaseId])
  @@index([tenantId])
  @@index([analysisType])
}

model Lead {
  id              String     @id @default(uuid())
  name            String
  email           String
  company         String
  jobTitle        String?
  phone           String?
  message         String?
  status          LeadStatus @default(NEW)
  source          String     @default("website")
  assignedTo      String?
  notes           String?
  followUpDate    DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model AiProvider {
  id          String         @id @default(uuid())
  name        String
  type        AiProviderType
  displayName String
  isActive    Boolean        @default(false)
  apiKey      String?
  baseUrl     String?
  model       String
  config      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([isActive])
  @@index([type])
}

model Risk {
  id          String       @id @default(uuid())
  title       String
  description String
  category    RiskCategory
  severity    RiskSeverity
  score       Float        @default(0)
  status      RiskStatus   @default(OPEN)
  tenantId    String
  releaseId   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  release     Release?     @relation(fields: [releaseId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([releaseId])
  @@index([severity])
  @@index([tenantId, severity])
}

model Release {
  id                  String        @id @default(uuid())
  version             String
  description         String?
  engineeringScore    Float         @default(0)
  userJourneyScore    Float         @default(0)
  releaseRiskIndex    Float         @default(0)
  deploymentDate      DateTime
  status              ReleaseStatus @default(PENDING)
  prSize              Int?
  reviewDurationHours Float?
  failedBuildRate     Float?
  testCoverage        Float?
  deploymentsPerWeek  Int?
  reopenedIssues      Int?
  tenantId            String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  risks               Risk[]
  aiAnalysisResults   AiAnalysisResult[]

  @@unique([version, tenantId])
  @@index([tenantId])
  @@index([deploymentDate])
  @@index([tenantId, deploymentDate])
}

model UserJourneyFlow {
  id             String   @id @default(uuid())
  name           String
  dropoffRate    Float    @default(0)
  incidentCount  Int      @default(0)
  stabilityScore Float    @default(0)
  tenantId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId])
}

model Notification {
  id          String               @id @default(uuid())
  title       String
  description String?
  type        NotificationType
  status      NotificationStatus   @default(UNREAD)
  riskId      String?
  releaseId   String?
  userId      String?
  tenantId    String
  metadata    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  metadata  Json?
  tenantId  String
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([entity, entityId])
  @@index([tenantId, createdAt])
}

enum UserRole {
  OWNER
  ADMIN
  VIEWER
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskCategory {
  ENGINEERING
  USER_JOURNEY
  RELEASE_PROCESS
  SECURITY
  PERFORMANCE
}

enum RiskStatus {
  OPEN
  IN_PROGRESS
  MITIGATED
  CLOSED
}

enum ReleaseStatus {
  PENDING
  DEPLOYED
  ROLLED_BACK
  CANCELLED
}

enum AiProviderType {
  OPENAI
  GEMINI
  OLLAMA
}
enum NotificationType {
  RISK_CREATED
  RISK_UPDATED
  RISK_SEVERITY_CHANGED
  RELEASE_CREATED
  RELEASE_DEPLOYED
  RELEASE_FAILED
  HIGH_RISK_ALERT
}

enum NotificationStatus {
  UNREAD
  READ
  DISMISSED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DEMO_SCHEDULED
  DEMO_COMPLETED
  PROPOSAL_SENT
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

// =========================
// INTEGRATION MODELS (Phase 2)
// =========================

model GitIntegration {
  id              String              @id @default(uuid())
  tenantId        String              @unique
  provider        GitProvider
  repoOwner       String              // e.g., "facebook"
  repoName        String              // e.g., "react"
  accessToken     String              // Encrypted PAT or OAuth token
  webhookSecret   String?             // For incoming webhooks
  isActive        Boolean             @default(true)
  lastSyncAt      DateTime?
  syncStatus      IntegrationStatus   @default(PENDING)
  syncError       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relation to tenant (one-to-one per tenant for simplicity)
  syncLogs        GitSyncLog[]

  @@index([tenantId])
  @@index([provider])
}

model GitSyncLog {
  id              String            @id @default(uuid())
  integrationId   String
  syncType        String            // 'pull_requests', 'commits', 'reviews'
  recordsFound    Int               @default(0)
  recordsSynced   Int               @default(0)
  status          IntegrationStatus
  errorMessage    String?
  startedAt       DateTime          @default(now())
  completedAt     DateTime?
  
  integration     GitIntegration    @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([syncType])
}

model CICDIntegration {
  id              String              @id @default(uuid())
  tenantId        String              @unique
  provider        CICDProvider
  projectId       String?             // For Jenkins/CircleCI project identifier
  accessToken     String?             // API token
  webhookUrl      String?             // Our webhook endpoint for push events
  webhookSecret   String?
  isActive        Boolean             @default(true)
  lastSyncAt      DateTime?
  syncStatus      IntegrationStatus   @default(PENDING)
  syncError       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  syncLogs        CICDSyncLog[]

  @@index([tenantId])
  @@index([provider])
}

model CICDSyncLog {
  id              String            @id @default(uuid())
  integrationId   String
  syncType        String            // 'builds', 'deployments', 'coverage'
  recordsFound    Int               @default(0)
  recordsSynced   Int               @default(0)
  status          IntegrationStatus
  errorMessage    String?
  startedAt       DateTime          @default(now())
  completedAt     DateTime?
  
  integration     CICDIntegration   @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
  @@index([syncType])
}

// Synced data from Git provider
model PullRequestData {
  id                String    @id @default(uuid())
  tenantId          String
  externalId        String    // PR number or ID from provider
  title             String
  author            String
  state             String    // open, closed, merged
  linesAdded        Int       @default(0)
  linesDeleted      Int       @default(0)
  filesChanged      Int       @default(0)
  reviewCount       Int       @default(0)
  reviewDurationHrs Float?    // Time from open to first review
  mergedAt          DateTime?
  createdAt         DateTime
  updatedAt         DateTime  @updatedAt
  syncedAt          DateTime  @default(now())

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
}

// Synced data from CI/CD provider
model BuildData {
  id              String    @id @default(uuid())
  tenantId        String
  externalId      String    // Build ID from provider
  branch          String?
  commitSha       String?
  status          String    // success, failure, cancelled
  duration        Int?      // seconds
  testsPassed     Int?
  testsFailed     Int?
  testCoverage    Float?
  triggeredBy     String?
  startedAt       DateTime?
  finishedAt      DateTime?
  syncedAt        DateTime  @default(now())

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([tenantId, startedAt])
}

// Risk Correlation results
model RiskCorrelation {
  id              String    @id @default(uuid())
  tenantId        String
  signalA         String    // e.g., 'pr_size'
  signalB         String    // e.g., 'incident_count'
  correlation     Float     // -1 to 1 (Pearson coefficient)
  strength        CorrelationStrength
  sampleSize      Int       @default(0)
  periodDays      Int       @default(30)
  insight         String?   // AI-generated insight
  calculatedAt    DateTime  @default(now())

  @@unique([tenantId, signalA, signalB])
  @@index([tenantId])
  @@index([strength])
}

enum GitProvider {
  GITHUB
  GITLAB
  BITBUCKET
}

enum CICDProvider {
  GITHUB_ACTIONS
  GITLAB_CI
  JENKINS
  CIRCLECI
}

enum IntegrationStatus {
  PENDING
  SYNCING
  SUCCESS
  FAILED
}

enum CorrelationStrength {
  STRONG_POSITIVE   // > 0.7
  MODERATE_POSITIVE // 0.4 to 0.7
  WEAK_POSITIVE     // 0.1 to 0.4
  NONE              // -0.1 to 0.1
  WEAK_NEGATIVE     // -0.4 to -0.1
  MODERATE_NEGATIVE // -0.7 to -0.4
  STRONG_NEGATIVE   // < -0.7
}